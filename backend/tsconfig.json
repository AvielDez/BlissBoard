{
  "compilerOptions": {
    "target": "ES6",                                
    "module": "CommonJS",                       
    "rootDir": "./src",                            
    "outDir": "./dist",                                   
    "esModuleInterop": true,                             
    "forceConsistentCasingInFileNames": true,            
    "strict": true,                                    
    "skipLibCheck": true,
    "lib": ["esnext"]                             
  },
  "include": ["src/**/*.ts", "src/index.mjs"],
  "exclude": ["node_modules"]
}
