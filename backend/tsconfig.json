  "compilerOptions": {
    "target": "ESNext",         // Set the target JavaScript version
    "module": "CommonJS",       // Specify the module system (CommonJS for Node.js)
    "outDir": "./dist",         // Output directory for compiled files
    "rootDir": "./src",         // Source directory for TypeScript files
    "strict": true,             // Enable strict type checking
    "esModuleInterop": true,    // Enable ES module interop
    "skipLibCheck": true,       // Skip type checking of declaration files
    "forceConsistentCasingInFileNames": true, // Enforce consistent filename casing
    "resolveJsonModule": true,  // Enable JSON module import
    "allowSyntheticDefaultImports": true, // Allow default imports from modules with no default export
    "sourceMap": true           // Generate source maps for debugging
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  },
  "include": [
    "src/**/*.ts"              // Specify which files to include in compilation
  ],
  "exclude": [
    "node_modules"             // Specify files or directories to exclude from compilation
  ]
}
